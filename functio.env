cat > test-simple-post.js << 'EOF'
// test-simple-post.js - シンプルな投稿テスト
const xmlrpc = require('xmlrpc');
require('dotenv').config();

const wpUrl = process.env.WP_URL;
const username = process.env.WP_USERNAME;
const password = process.env.WP_PASSWORD;

console.log('🔧 Configuration:', {
  url: wpUrl,
  username: username,
  passwordLength: password ? password.length : 0,
  passwordFormat: password ? (password.includes(' ') ? 'with spaces' : 'no spaces') : 'missing'
});

// パスワードのバリエーションをテスト
const passwords = [
  password,  // 元のパスワード
  password ? password.replace(/\s/g, '') : '',  // スペースを除去
];

async function testWithPassword(pwd, description) {
  return new Promise((resolve) => {
    console.log(`\n📝 Testing ${description}...`);
    console.log(`Password length: ${pwd.length}`);
    
    const client = xmlrpc.createClient({
      url: `${wpUrl}/xmlrpc.php`,
      basic_auth: {
        user: username,
        pass: pwd
      }
    });

    // 最もシンプルな投稿データ
    const postData = {
      post_title: 'テスト投稿 ' + new Date().toISOString(),
      post_content: '<p>これはテスト投稿です。</p>',
      post_status: 'draft'  // まずは下書きで投稿
    };

    client.methodCall(
      'wp.newPost',
      [1, username, pwd, postData],
      (error, postId) => {
        if (error) {
          console.error(`❌ Failed with ${description}:`, error.message || error);
          
          // エラーの詳細を確認
          if (error.toString().includes('TITLE')) {
            console.error('   → HTML error page returned (authentication failed)');
          } else if (error.code === 403) {
            console.error('   → Authentication failed (403)');
          } else if (error.faultCode === 403) {
            console.error('   → XML-RPC authentication failed');
          }
          
          resolve(false);
        } else {
          console.log(`✅ Success with ${description}! Post ID:`, postId);
          console.log('View at:', `${wpUrl}/wp-admin/post.php?post=${postId}&action=edit`);
          resolve(true);
        }
      }
    );
  });
}

// 両方のパスワード形式をテスト
async function runTests() {
  console.log('🚀 Starting authentication tests...\n');
  
  // オリジナルのパスワード
  const result1 = await testWithPassword(passwords[0], 'original password');
  
  if (!result1 && passwords[0] !== passwords[1]) {
    // スペースなしバージョン
    const result2 = await testWithPassword(passwords[1], 'password without spaces');
    
    if (result2) {
      console.log('\n✅ Success! Use password WITHOUT spaces in .env file:');
      console.log(`WP_PASSWORD=${passwords[1]}`);
    }
  }
  
  if (!result1 && !(passwords[0] !== passwords[1] && await testWithPassword(passwords[1], 'password without spaces'))) {
    console.log('\n❌ Both password formats failed.');
    console.log('\n📋 Next steps:');
    console.log('1. Go to: https://www.entamade.jp/wp-admin/profile.php');
    console.log('2. Scroll to "Application Passwords"');
    console.log('3. Create new password with name: Firebase');
    console.log('4. Copy the generated password');
    console.log('5. Update .env file with the new password');
  }
}

runTests();
EOF

echo "✅ test-simple-post.js created"
